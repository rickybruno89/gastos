datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id                         String                     @id @default(cuid())
  name                       String?
  email                      String?                    @unique
  emailVerified              DateTime?
  image                      String?
  accounts                   Account[]
  sessions                   Session[]
  sharedPaymentPersons       Person[]
  expenses                   Expense[]
  expensePaymentSummaries    ExpensePaymentSummary[]
  creditCards                CreditCard[]
  creditCardPaymentSummaries CreditCardPaymentSummary[]
  creditCardExpenseItems     CreditCardExpenseItem[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Person {
  id                           String                  @id @default(cuid())
  name                         String
  sharedExpenses               Expense[]
  sharedCreditCardExpenseItems CreditCardExpenseItem[]
  user                         User                    @relation(fields: [userId], references: [id])
  userId                       String
  deleted                      Boolean                 @default(false)
  deletedAt                    DateTime?

  @@unique([name, userId])
}

enum PaymentChannel {
  EFECTIVO
  BANCARIZADO
  DEBITO_AUTOMATICO
}

enum Currency {
  ARS
  USD
}

model CreditCard {
  id                     String                     @id @default(cuid())
  name                   String
  lastFourDigits         String?
  color                  String                     @default("#143273")
  textColor              String                     @default("#FFFFFF")
  defaultCurrency        Currency                   @default(ARS)
  paymentSummaries       CreditCardPaymentSummary[]
  creditCardExpenseItems CreditCardExpenseItem[]
  user                   User                       @relation(fields: [userId], references: [id])
  userId                 String
  deleted                Boolean                    @default(false)
  deletedAt              DateTime?
  createdAt              DateTime                   @default(now())
  updatedAt              DateTime                   @updatedAt
}

model CreditCardExpenseItem {
  id                   String                         @id @default(cuid())
  description          String
  notes                String
  amount               Float                          @default(0) // only for items with installments (this is the total amount)
  currency             Currency                       @default(ARS)
  sharedWith           Person[]
  recurrent            Boolean
  installmentsQuantity Int                            @default(0)
  installmentsPaid     Int                            @default(0)
  installmentsAmount   Float // this is the amount for recurrent items TOO
  paymentBeginning     String
  finished             Boolean                        @default(false)
  finishedAt           DateTime?
  creditCard           CreditCard                     @relation(fields: [creditCardId], references: [id])
  creditCardId         String
  paymentHistory       CreditCardSummaryExpenseItem[]
  installmentPayments  InstallmentPayment[]
  user                 User                           @relation(fields: [userId], references: [id])
  userId               String
  deleted              Boolean                        @default(false)
  deletedAt            DateTime?
  createdAt            DateTime                       @default(now())
  updatedAt            DateTime                       @updatedAt

  @@index([finished, recurrent])
}

model CreditCardSummaryExpenseItem {
  id                         String                   @id @default(cuid())
  creditCardExpenseItem      CreditCardExpenseItem    @relation(fields: [creditCardExpenseItemId], references: [id])
  creditCardExpenseItemId    String
  creditCardPaymentSummary   CreditCardPaymentSummary @relation(fields: [creditCardPaymentSummaryId], references: [id])
  creditCardPaymentSummaryId String
  installmentsPaid           Int                      @default(0)
  installmentsAmount         Float                    @default(0)
  installmentsQuantity       Int                      @default(0)
}

model InstallmentPayment {
  id                         String                    @id @default(cuid())
  creditCardExpenseItem      CreditCardExpenseItem     @relation(fields: [creditCardExpenseItemId], references: [id])
  creditCardExpenseItemId    String
  creditCardPaymentSummary   CreditCardPaymentSummary? @relation(fields: [creditCardPaymentSummaryId], references: [id])
  creditCardPaymentSummaryId String?
  installmentNumber          Int
  amount                     Float
  currency                   Currency                  @default(ARS)
  isPaid                     Boolean                   @default(false)
  paymentDate                String?
  createdAt                  DateTime                  @default(now())
  updatedAt                  DateTime                  @updatedAt

  @@unique([creditCardExpenseItemId, installmentNumber])
  @@index([isPaid, paymentDate])
}

model CreditCardPaymentSummary {
  id                  String                         @id @default(cuid())
  date                String
  amount              Float
  paid                Boolean                        @default(false)
  dueDate             String
  taxes               Float                          @default(0)
  summarySequence     Int?
  totalAmountARS      Float?
  totalAmountUSD      Float?
  taxesARS            Float                          @default(0)
  taxesUSD            Float                          @default(0)
  creditBalanceARS    Float                          @default(0)
  creditBalanceUSD    Float                          @default(0)
  itemHistoryPayment  CreditCardSummaryExpenseItem[]
  installmentPayments InstallmentPayment[]
  creditCard          CreditCard                     @relation(fields: [creditCardId], references: [id])
  creditCardId        String
  user                User                           @relation(fields: [userId], references: [id])
  userId              String
  createdAt           DateTime                       @default(now())
  updatedAt           DateTime                       @updatedAt

  @@unique([creditCardId, date])
  @@unique([creditCardId, summarySequence])
}

model Expense {
  id                String                  @id @default(cuid())
  description       String
  notes             String
  amount            Float
  currency          Currency                @default(ARS)
  dueDate           String?
  sharedWith        Person[]
  paymentChannel    PaymentChannel          @default(BANCARIZADO)
  isAnnualPayment   Boolean                 @default(false)
  annualPaymentDate String?
  user              User                    @relation(fields: [userId], references: [id])
  userId            String
  paymentSummaries  ExpensePaymentSummary[]
  deleted           Boolean                 @default(false)
  deletedAt         DateTime?
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt
}

model ExpensePaymentSummary {
  id             String         @id @default(cuid())
  expense        Expense        @relation(fields: [expenseId], references: [id])
  expenseId      String
  date           String
  dueDate        String?
  amount         Float
  currency       Currency       @default(ARS)
  paid           Boolean        @default(false)
  paymentChannel PaymentChannel @default(BANCARIZADO)
  user           User           @relation(fields: [userId], references: [id])
  userId         String
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@unique([expenseId, date])
}

model Invoice {
  id                String @id @default(cuid())
  contractorName    String
  personalEmail     String
  personalStreet    String
  personalState     String
  personalZip       String
  destinationName   String
  destinationStreet String
  destinationState  String
  destinationZip    String
  destinationEmail  String
  destinationTaxId  String
  bankName          String
  bankAddress       String
  bankRoutingNumber String
  bankAccountNumber String
  bankAccountType   String
  arsPayment        Float  @default(0)
  usdPayment        Float  @default(0)
}
